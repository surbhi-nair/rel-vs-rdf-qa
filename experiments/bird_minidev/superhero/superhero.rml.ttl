@prefix rr:   <http://www.w3.org/ns/r2rml#> .
@prefix rml:  <http://semweb.mmlab.be/ns/rml#> .
@prefix ql:   <http://semweb.mmlab.be/ns/ql#> .
@prefix hero: <http://superhero.org/schema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .

######################################################################
# 1) Alignment
######################################################################
<#AlignmentMapping>
  rml:logicalSource [
    rml:source "superhero.sqlite" ;
    rml:referenceFormulation ql:SQL ;
    rml:query "SELECT id, alignment FROM alignment"
  ] ;
  rr:subjectMap [ rr:template "http://superhero.org/alignment/{id}" ; rr:class hero:Alignment ] ;
  rr:predicateObjectMap [ rr:predicate rdfs:label ; rr:objectMap [ rml:reference "alignment" ] ] ;
  rr:predicateObjectMap [ rr:predicate hero:alignmentType ; rr:objectMap [ rml:reference "alignment" ] ] .

######################################################################
# 2) Attribute
######################################################################
<#AttributeMapping>
  rml:logicalSource [
    rml:source "superhero.sqlite" ;
    rml:referenceFormulation ql:SQL ;
    rml:query "SELECT id, attribute_name FROM attribute"
  ] ;
  rr:subjectMap [ rr:template "http://superhero.org/attribute/{id}" ; rr:class hero:Attribute ] ;
  rr:predicateObjectMap [ rr:predicate rdfs:label ; rr:objectMap [ rml:reference "attribute_name" ] ] ;
  rr:predicateObjectMap [ rr:predicate hero:attributeName ; rr:objectMap [ rml:reference "attribute_name" ] ] .

######################################################################
# 3) Colour
######################################################################
<#ColourMapping>
  rml:logicalSource [
    rml:source "superhero.sqlite" ;
    rml:referenceFormulation ql:SQL ;
