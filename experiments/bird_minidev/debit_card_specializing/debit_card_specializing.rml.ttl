@prefix rr:   <http://www.w3.org/ns/r2rml#> .
@prefix rml:  <http://semweb.mmlab.be/ns/rml#> .
@prefix ql:   <http://semweb.mmlab.be/ns/ql#> .
@prefix dcs:  <http://debitcard.org/schema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .

######################################################################
# 1) Customers Mapping
######################################################################
<#CustomersMapping>
  rml:logicalSource [
    rml:source "debit_card_specializing.sqlite" ;
    rml:referenceFormulation ql:SQL ;
    rml:query """
    SELECT 
      CustomerID, 
      Segment, 
      Currency
    FROM customers
    """
  ] ;

  rr:subjectMap [ rr:template "http://debitcard.org/customer/{CustomerID}" ; rr:class dcs:Customer ] ;

  rr:predicateObjectMap [ rr:predicate rdfs:label ; rr:objectMap [ rr:template "Customer {CustomerID} ({Segment})" ] ] ;
  rr:predicateObjectMap [ rr:predicate dcs:customerID ; rr:objectMap [ rml:reference "CustomerID" ] ] ;
  rr:predicateObjectMap [ rr:predicate dcs:segment ; rr:objectMap [ rml:reference "Segment" ] ] ;
  rr:predicateObjectMap [ rr:predicate dcs:currency ; rr:objectMap [ rml:reference "Currency" ] ] .

######################################################################
# 2) Gas Stations Mapping
######################################################################
<#GasStationsMapping>
  rml:logicalSource [
    rml:source "debit_card_specializing.sqlite" ;
    rml:referenceFormulation ql:SQL ;
    rml:query """
    SELECT 
      GasStationID, 
      ChainID, 
      Country, 
      Segment
    FROM gasstations
    """
  ] ;

  rr:subjectMap [ rr:template "http://debitcard.org/gasstation/{GasStationID}" ; rr:class dcs:GasStation ] ;

  rr:predicateObjectMap [ rr:predicate rdfs:label ; rr:objectMap [ rr:template "Gas Station {GasStationID} ({Country})" ] ] ;
  rr:predicateObjectMap [ rr:predicate dcs:country ; rr:objectMap [ rml:reference "Country" ] ] ;
  rr:predicateObjectMap [ rr:predicate dcs:chainID ; rr:objectMap [ rml:reference "ChainID" ; rr:datatype xsd:integer ] ] ;
  rr:predicateObjectMap [ rr:predicate dcs:segment ; rr:objectMap [ rml:reference "Segment" ] ] .

######################################################################
# 3) Products Mapping
######################################################################
<#ProductsMapping>
  rml:logicalSource [
    rml:source "debit_card_specializing.sqlite" ;
    rml:referenceFormulation ql:SQL ;
    rml:query "SELECT ProductID, Description FROM products"
  ] ;

  rr:subjectMap [ rr:template "http://debitcard.org/product/{ProductID}" ; rr:class dcs:Product ] ;

  rr:predicateObjectMap [ rr:predicate rdfs:label ; rr:objectMap [ rr:template "{Description}" ] ] ;
  rr:predicateObjectMap [ rr:predicate dcs:productDescription ; rr:objectMap [ rml:reference "Description" ] ] .

######################################################################
# 4) Transactions Mapping
######################################################################
<#TransactionsMapping>
  rml:logicalSource [
    rml:source "debit_card_specializing.sqlite" ;
    rml:referenceFormulation ql:SQL ;
    rml:query """
    SELECT 
      TransactionID, 
      Date, 
      Time, 
      CustomerID, 
      CardID, 
      GasStationID, 
      ProductID, 
      Amount, 
      CAST(Price AS TEXT) AS Price,
      CAST(ROUND(Amount * Price, 2) AS TEXT) AS TotalPrice
    FROM transactions_1k
    """
  ] ;

  rr:subjectMap [ rr:template "http://debitcard.org/transaction/{TransactionID}" ; rr:class dcs:Transaction ] ;

  rr:predicateObjectMap [ rr:predicate rdfs:label ; rr:objectMap [ rr:template "Transaction {TransactionID}" ] ] ;
  rr:predicateObjectMap [ rr:predicate dcs:date ; rr:objectMap [ rml:reference "Date" ; rr:datatype xsd:date ] ] ;
  rr:predicateObjectMap [ rr:predicate dcs:time ; rr:objectMap [ rml:reference "Time" ] ] ;
  rr:predicateObjectMap [ rr:predicate dcs:amount ; rr:objectMap [ rml:reference "Amount" ; rr:datatype xsd:integer ] ] ;
  rr:predicateObjectMap [ rr:predicate dcs:pricePerUnit ; rr:objectMap [ rml:reference "Price" ; rr:datatype xsd:decimal ] ] ;
  rr:predicateObjectMap [ rr:predicate dcs:totalPrice ; rr:objectMap [ rml:reference "TotalPrice" ; rr:datatype xsd:decimal ] ] ;
  rr:predicateObjectMap [ rr:predicate dcs:madeBy ; rr:objectMap [ rr:template "http://debitcard.org/customer/{CustomerID}" ; rr:termType rr:IRI ] ] ;
  rr:predicateObjectMap [ rr:predicate dcs:atStation ; rr:objectMap [ rr:template "http://debitcard.org/gasstation/{GasStationID}" ; rr:termType rr:IRI ] ] ;
  rr:predicateObjectMap [ rr:predicate dcs:includesProduct ; rr:objectMap [ rr:template "http://debitcard.org/product/{ProductID}" ; rr:termType rr:IRI ] ] ;
  rr:predicateObjectMap [ rr:predicate dcs:cardUsed ; rr:objectMap [ rml:reference "CardID" ] ] .

######################################################################
# 5) Year-Month Consumption Mapping
######################################################################
<#YearMonthMapping>
  rml:logicalSource [
    rml:source "debit_card_specializing.sqlite" ;
    rml:referenceFormulation ql:SQL ;
    rml:query """
    SELECT 
      CustomerID, 
      Date, 
      CAST(Consumption AS TEXT) AS Consumption
    FROM yearmonth
    """
  ] ;

  rr:subjectMap [ rr:template "http://debitcard.org/consumption/{CustomerID}-{Date}" ; rr:class dcs:MonthlyConsumption ] ;

  rr:predicateObjectMap [ rr:predicate rdfs:label ; rr:objectMap [ rr:template "Consumption ({Date})" ] ] ;
  rr:predicateObjectMap [ rr:predicate dcs:consumptionValue ; rr:objectMap [ rml:reference "Consumption" ; rr:datatype xsd:decimal ] ] ;
  rr:predicateObjectMap [ rr:predicate dcs:forCustomer ; rr:objectMap [ rr:template "http://debitcard.org/customer/{CustomerID}" ; rr:termType rr:IRI ] ] ;
  rr:predicateObjectMap [ rr:predicate dcs:date ; rr:objectMap [ rml:reference "Date" ; rr:datatype xsd:date ] ] .