<#ConstructorStandingsMapping>
  rml:logicalSource [
    rml:source "formula_1.sqlite";
    rml:referenceFormulation ql:SQL;
    rml:query """
      SELECT constructorStandingsId, raceId, constructorId, points, position, positionText, wins
      FROM constructorStandings
