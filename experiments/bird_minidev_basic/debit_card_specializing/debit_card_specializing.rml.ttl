######################################################################
# Table: yearmonth
######################################################################
<#yearmonth_Mapping>
  rml:logicalSource [
    rml:source "debit_card_specializing.sqlite" ;
    rml:referenceFormulation ql:SQL ;
    rml:query '''SELECT "CustomerID", "Date", "Consumption" FROM "yearmonth"'''
  ] ;
  rr:subjectMap [
    rr:template "http://debit_card_specializing.org/yearmonth/CustomerID={CustomerID};Date={Date}" ;
    rr:class <http://debit_card_specializing.org/yearmonth>
  ] ;
  rr:predicateObjectMap [
    rr:predicate rdfs:label ;
    rr:objectMap [
      rr:template "yearmonth {CustomerID}" ;
      rr:termType rr:Literal
    ]
  ]
 ;
  rr:predicateObjectMap [
    rr:predicate <http://debit_card_specializing.org/yearmonth#CustomerID> ;
    rr:objectMap [ rml:reference "CustomerID" ]
  ] ;
  rr:predicateObjectMap [
    rr:predicate <http://debit_card_specializing.org/yearmonth#ref-CustomerID> ;
    rr:objectMap [
      rr:template "http://debit_card_specializing.org/customers/CustomerID={CustomerID}" ;
      rr:termType rr:IRI
    ]
  ] ;
  rr:predicateObjectMap [
    rr:predicate <http://debit_card_specializing.org/yearmonth#Date> ;
    rr:objectMap [ rml:reference "Date" ]
  ] ;
  rr:predicateObjectMap [
    rr:predicate <http://debit_card_specializing.org/yearmonth#Consumption> ;
    rr:objectMap [ rml:reference "Consumption" ]
  ]
 .
