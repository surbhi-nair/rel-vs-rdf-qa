@prefix rr: <http://www.w3.org/ns/r2rml#> .
@prefix rml: <http://semweb.mmlab.be/ns/rml#> .
@prefix ql: <http://semweb.mmlab.be/ns/ql#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix : <http://debit_card_specializing.org/> .

######################################################################
# Table: customers
######################################################################
<#customers_Mapping>
  rml:logicalSource [
    rml:source "debit_card_specializing.sqlite" ;
    rml:referenceFormulation ql:SQL ;
    rml:query '''SELECT "CustomerID", "Segment", "Currency" FROM "customers"'''
  ] ;
  rr:subjectMap [
    rr:template "http://debit_card_specializing.org/customers/CustomerID={CustomerID}" ;
    rr:class <http://debit_card_specializing.org/customers>
  ] ;
  rr:predicateObjectMap [
    rr:predicate rdfs:label ;
    rr:objectMap [
      rr:template "customers {CustomerID}" ;
      rr:termType rr:Literal
    ]
  ]
 ;
  rr:predicateObjectMap [
    rr:predicate <http://debit_card_specializing.org/customers#CustomerID> ;
    rr:objectMap [ rml:reference "CustomerID" ]
  ] ;
  rr:predicateObjectMap [
    rr:predicate <http://debit_card_specializing.org/customers#Segment> ;
    rr:objectMap [ rml:reference "Segment" ]
  ] ;
  rr:predicateObjectMap [
    rr:predicate <http://debit_card_specializing.org/customers#Currency> ;
    rr:objectMap [ rml:reference "Currency" ]
  ]
 .

