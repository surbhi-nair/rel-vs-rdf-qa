######################################################################
# Table: circuits
######################################################################
<#circuits_Mapping>
  rml:logicalSource [
    rml:source "formula_1.sqlite" ;
    rml:referenceFormulation ql:SQL ;
    rml:query '''SELECT "circuitId", "circuitRef", "name", "location", "country", "lat", "lng", "alt", "url" FROM "circuits"'''
  ] ;
  rr:subjectMap [
    rr:template "http://formula_1.org/circuits/circuitId={circuitId}" ;
    rr:class <http://formula_1.org/circuits>
  ] ;
  rr:predicateObjectMap [
    rr:predicate rdfs:label ;
    rr:objectMap [
      rr:template "circuits {circuitId}" ;
      rr:termType rr:Literal
    ]
  ]
 ;
  rr:predicateObjectMap [
    rr:predicate <http://formula_1.org/circuits#circuitId> ;
    rr:objectMap [ rml:reference "circuitId" ]
  ] ;
  rr:predicateObjectMap [
    rr:predicate <http://formula_1.org/circuits#circuitRef> ;
    rr:objectMap [ rml:reference "circuitRef" ]
  ] ;
  rr:predicateObjectMap [
    rr:predicate <http://formula_1.org/circuits#name> ;
    rr:objectMap [ rml:reference "name" ]
  ] ;
  rr:predicateObjectMap [
    rr:predicate <http://formula_1.org/circuits#location> ;
    rr:objectMap [ rml:reference "location" ]
  ] ;
  rr:predicateObjectMap [
    rr:predicate <http://formula_1.org/circuits#country> ;
    rr:objectMap [ rml:reference "country" ]
  ] ;
