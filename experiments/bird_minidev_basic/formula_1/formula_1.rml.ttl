# Table: results
######################################################################
<#results_Mapping>
  rml:logicalSource [
    rml:source "formula_1.sqlite" ;
    rml:referenceFormulation ql:SQL ;
    rml:query '''SELECT "resultId", "raceId", "driverId", "constructorId", "number", "grid", "position", "positionText", "positionOrder", "points", "laps", "time", "milliseconds", "fastestLap", "rank", "fastestLapTime", "fastestLapSpeed", "statusId" FROM "results"'''
  ] ;
  rr:subjectMap [
    rr:template "http://formula_1.org/results/resultId={resultId}" ;
    rr:class <http://formula_1.org/results>
  ] ;
  rr:predicateObjectMap [
    rr:predicate rdfs:label ;
    rr:objectMap [
      rr:template "results {resultId}" ;
      rr:termType rr:Literal
    ]
  ]
 ;
