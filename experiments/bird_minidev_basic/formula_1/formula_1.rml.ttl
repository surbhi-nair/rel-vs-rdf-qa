<#status_Mapping>
  rml:logicalSource [
    rml:source "formula_1.sqlite" ;
    rml:referenceFormulation ql:SQL ;
    rml:query '''SELECT "statusId", "status" FROM "status"'''
  ] ;
  rr:subjectMap [
    rr:template "http://formula_1.org/status/statusId={statusId}" ;
    rr:class <http://formula_1.org/status>
  ] ;
  rr:predicateObjectMap [
    rr:predicate rdfs:label ;
    rr:objectMap [
      rr:template "status {statusId}" ;
      rr:termType rr:Literal
    ]
  ]
 ;
  rr:predicateObjectMap [
    rr:predicate <http://formula_1.org/status#statusId> ;
    rr:objectMap [ rml:reference "statusId" ]
  ] ;
  rr:predicateObjectMap [
    rr:predicate <http://formula_1.org/status#status> ;
    rr:objectMap [ rml:reference "status" ]
  ]
 .

