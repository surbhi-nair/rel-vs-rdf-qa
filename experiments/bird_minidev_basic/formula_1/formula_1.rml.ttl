    rr:predicate <http://formula_1.org/circuits#lat> ;
    rr:objectMap [ rml:reference "lat" ]
  ] ;
  rr:predicateObjectMap [
    rr:predicate <http://formula_1.org/circuits#lng> ;
    rr:objectMap [ rml:reference "lng" ]
  ] ;
  rr:predicateObjectMap [
    rr:predicate <http://formula_1.org/circuits#alt> ;
    rr:objectMap [ rml:reference "alt" ]
  ] ;
  rr:predicateObjectMap [
    rr:predicate <http://formula_1.org/circuits#url> ;
    rr:objectMap [ rml:reference "url" ]
  ]
 .

