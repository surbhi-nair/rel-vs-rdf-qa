@prefix rr: <http://www.w3.org/ns/r2rml#> .
@prefix rml: <http://semweb.mmlab.be/ns/rml#> .
@prefix ql: <http://semweb.mmlab.be/ns/ql#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix : <http://thrombosis_prediction.org/> .

######################################################################
# Table: Examination
######################################################################
<#Examination_Mapping>
  rml:logicalSource [
    rml:source "thrombosis_prediction.sqlite" ;
    rml:referenceFormulation ql:SQL ;
    rml:query '''SELECT "ID", "Examination Date", "aCL IgG", "aCL IgM", "ANA", "ANA Pattern", "aCL IgA", "Diagnosis", "KCT", "RVVT", "LAC", "Symptoms", "Thrombosis" FROM "Examination"'''
  ] ;
  rr:subjectMap [
    rr:template "http://thrombosis_prediction.org/Examination/ID={ID}" ;
    rr:class <http://thrombosis_prediction.org/Examination>
  ] ;
  rr:predicateObjectMap [
    rr:predicate rdfs:label ;
    rr:objectMap [
      rr:template "Examination {ID}" ;
      rr:termType rr:Literal
    ]
  ]
 ;
  rr:predicateObjectMap [
    rr:predicate <http://thrombosis_prediction.org/Examination#ID> ;
    rr:objectMap [ rml:reference "ID" ]
  ] ;
  rr:predicateObjectMap [
    rr:predicate <http://thrombosis_prediction.org/Examination#ref-ID> ;
    rr:objectMap [
      rr:template "http://thrombosis_prediction.org/Patient/ID={ID}" ;
      rr:termType rr:IRI
    ]
  ] ;
  rr:predicateObjectMap [
    rr:predicate <http://thrombosis_prediction.org/Examination#Examination Date> ;
    rr:objectMap [ rml:reference "Examination Date" ]
  ] ;
  rr:predicateObjectMap [
    rr:predicate <http://thrombosis_prediction.org/Examination#aCL IgG> ;
    rr:objectMap [ rml:reference "aCL IgG" ]
  ] ;
  rr:predicateObjectMap [
    rr:predicate <http://thrombosis_prediction.org/Examination#aCL IgM> ;
    rr:objectMap [ rml:reference "aCL IgM" ]
  ] ;
  rr:predicateObjectMap [
    rr:predicate <http://thrombosis_prediction.org/Examination#ANA> ;
    rr:objectMap [ rml:reference "ANA" ]
  ] ;
  rr:predicateObjectMap [
    rr:predicate <http://thrombosis_prediction.org/Examination#ANA Pattern> ;
    rr:objectMap [ rml:reference "ANA Pattern" ]
  ] ;
  rr:predicateObjectMap [
    rr:predicate <http://thrombosis_prediction.org/Examination#aCL IgA> ;
    rr:objectMap [ rml:reference "aCL IgA" ]
  ] ;
  rr:predicateObjectMap [
    rr:predicate <http://thrombosis_prediction.org/Examination#Diagnosis> ;
    rr:objectMap [ rml:reference "Diagnosis" ]
  ] ;
  rr:predicateObjectMap [
    rr:predicate <http://thrombosis_prediction.org/Examination#KCT> ;
    rr:objectMap [ rml:reference "KCT" ]
  ] ;
  rr:predicateObjectMap [
    rr:predicate <http://thrombosis_prediction.org/Examination#RVVT> ;
    rr:objectMap [ rml:reference "RVVT" ]
  ] ;
  rr:predicateObjectMap [
    rr:predicate <http://thrombosis_prediction.org/Examination#LAC> ;
    rr:objectMap [ rml:reference "LAC" ]
  ] ;
  rr:predicateObjectMap [
    rr:predicate <http://thrombosis_prediction.org/Examination#Symptoms> ;
    rr:objectMap [ rml:reference "Symptoms" ]
  ] ;
  rr:predicateObjectMap [
    rr:predicate <http://thrombosis_prediction.org/Examination#Thrombosis> ;
    rr:objectMap [ rml:reference "Thrombosis" ]
  ]
 .

######################################################################
# Table: Patient
######################################################################
<#Patient_Mapping>
  rml:logicalSource [
    rml:source "thrombosis_prediction.sqlite" ;
    rml:referenceFormulation ql:SQL ;
    rml:query '''SELECT "ID", "SEX", "Birthday", "Description", "First Date", "Admission", "Diagnosis" FROM "Patient"'''
  ] ;
  rr:subjectMap [
    rr:template "http://thrombosis_prediction.org/Patient/ID={ID}" ;
    rr:class <http://thrombosis_prediction.org/Patient>
  ] ;
  rr:predicateObjectMap [
    rr:predicate rdfs:label ;
    rr:objectMap [
      rr:template "Patient {ID}" ;
      rr:termType rr:Literal
    ]
  ]
 ;
  rr:predicateObjectMap [
    rr:predicate <http://thrombosis_prediction.org/Patient#ID> ;
    rr:objectMap [ rml:reference "ID" ]
  ] ;
  rr:predicateObjectMap [
    rr:predicate <http://thrombosis_prediction.org/Patient#SEX> ;
    rr:objectMap [ rml:reference "SEX" ]
  ] ;
  rr:predicateObjectMap [
    rr:predicate <http://thrombosis_prediction.org/Patient#Birthday> ;
    rr:objectMap [ rml:reference "Birthday" ]
  ] ;
  rr:predicateObjectMap [
    rr:predicate <http://thrombosis_prediction.org/Patient#Description> ;
    rr:objectMap [ rml:reference "Description" ]
  ] ;
  rr:predicateObjectMap [
    rr:predicate <http://thrombosis_prediction.org/Patient#First Date> ;
    rr:objectMap [ rml:reference "First Date" ]
  ] ;
  rr:predicateObjectMap [
    rr:predicate <http://thrombosis_prediction.org/Patient#Admission> ;
    rr:objectMap [ rml:reference "Admission" ]
  ] ;
  rr:predicateObjectMap [
    rr:predicate <http://thrombosis_prediction.org/Patient#Diagnosis> ;
    rr:objectMap [ rml:reference "Diagnosis" ]
  ]
 .

