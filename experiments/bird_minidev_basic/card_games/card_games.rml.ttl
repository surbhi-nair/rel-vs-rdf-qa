    rml:referenceFormulation ql:SQL ;
    rml:query '''SELECT "id", "date", "text", "uuid" FROM "rulings"'''
  ] ;
  rr:subjectMap [
    rr:template "http://card_games.org/rulings/id={id}" ;
    rr:class <http://card_games.org/rulings>
  ] ;
  rr:predicateObjectMap [
    rr:predicate rdfs:label ;
    rr:objectMap [
      rr:template "rulings {id}" ;
      rr:termType rr:Literal
    ]
  ]
 ;
  rr:predicateObjectMap [
    rr:predicate <http://card_games.org/rulings#id> ;
    rr:objectMap [ rml:reference "id" ]
  ] ;
  rr:predicateObjectMap [
    rr:predicate <http://card_games.org/rulings#date> ;
    rr:objectMap [ rml:reference "date" ]
  ] ;
  rr:predicateObjectMap [
    rr:predicate <http://card_games.org/rulings#text> ;
    rr:objectMap [ rml:reference "text" ]
  ] ;
  rr:predicateObjectMap [
    rr:predicate <http://card_games.org/rulings#uuid> ;
    rr:objectMap [ rml:reference "uuid" ]
  ] ;
  rr:predicateObjectMap [
    rr:predicate <http://card_games.org/rulings#ref-uuid> ;
    rr:objectMap [
      rr:template "http://card_games.org/cards/id={uuid}" ;
      rr:termType rr:IRI
    ]
  ]
 .
