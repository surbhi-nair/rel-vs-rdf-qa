######################################################################
# Table: foreign_data
######################################################################
<#foreign_data_Mapping>
  rml:logicalSource [
    rml:source "card_games.sqlite" ;
    rml:referenceFormulation ql:SQL ;
    rml:query '''SELECT "id", "flavorText", "language", "multiverseid", "name", "text", "type", "uuid" FROM "foreign_data"'''
  ] ;
  rr:subjectMap [
    rr:template "http://card_games.org/foreign_data/id={id}" ;
    rr:class <http://card_games.org/foreign_data>
  ] ;
  rr:predicateObjectMap [
    rr:predicate rdfs:label ;
    rr:objectMap [
      rr:template "foreign_data {id}" ;
      rr:termType rr:Literal
    ]
  ]
 ;
  rr:predicateObjectMap [
    rr:predicate <http://card_games.org/foreign_data#id> ;
    rr:objectMap [ rml:reference "id" ]
  ] ;
  rr:predicateObjectMap [
    rr:predicate <http://card_games.org/foreign_data#flavorText> ;
    rr:objectMap [ rml:reference "flavorText" ]
  ] ;
  rr:predicateObjectMap [
    rr:predicate <http://card_games.org/foreign_data#language> ;
    rr:objectMap [ rml:reference "language" ]
  ] ;
  rr:predicateObjectMap [
    rr:predicate <http://card_games.org/foreign_data#multiverseid> ;
    rr:objectMap [ rml:reference "multiverseid" ]
  ] ;
  rr:predicateObjectMap [
    rr:predicate <http://card_games.org/foreign_data#name> ;
    rr:objectMap [ rml:reference "name" ]
  ] ;
  rr:predicateObjectMap [
    rr:predicate <http://card_games.org/foreign_data#text> ;
    rr:objectMap [ rml:reference "text" ]
  ] ;
  rr:predicateObjectMap [
    rr:predicate <http://card_games.org/foreign_data#type> ;
    rr:objectMap [ rml:reference "type" ]
  ] ;
  rr:predicateObjectMap [
    rr:predicate <http://card_games.org/foreign_data#uuid> ;
    rr:objectMap [ rml:reference "uuid" ]
  ] ;
  rr:predicateObjectMap [
    rr:predicate <http://card_games.org/foreign_data#ref-uuid> ;
    rr:objectMap [
      rr:template "http://card_games.org/cards/id={uuid}" ;
      rr:termType rr:IRI
    ]
  ]
