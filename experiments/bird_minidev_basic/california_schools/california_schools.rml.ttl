######################################################################
# Table: frpm
######################################################################
<#frpm_Mapping>
  rml:logicalSource [
    rml:source "california_schools.sqlite" ;
    rml:referenceFormulation ql:SQL ;
    rml:query '''SELECT "CDSCode", "Academic Year", "County Code", "District Code", "School Code", "County Name", "District Name", "School Name", "District Type", "School Type", "Educational Option Type", "NSLP Provision Status", "Charter School (Y/N)", "Charter School Number", "Charter Funding Type", "IRC", "Low Grade", "High Grade", "Enrollment (K-12)", "Free Meal Count (K-12)", "Percent (%) Eligible Free (K-12)", "FRPM Count (K-12)", "Percent (%) Eligible FRPM (K-12)", "Enrollment (Ages 5-17)", "Free Meal Count (Ages 5-17)", "Percent (%) Eligible Free (Ages 5-17)", "FRPM Count (Ages 5-17)", "Percent (%) Eligible FRPM (Ages 5-17)", "2013-14 CALPADS Fall 1 Certification Status" FROM "frpm"'''
  ] ;
  rr:subjectMap [
    rr:template "http://california_schools.org/frpm/CDSCode={CDSCode}" ;
    rr:class <http://california_schools.org/frpm>
  ] ;
  rr:predicateObjectMap [
    rr:predicate rdfs:label ;
    rr:objectMap [
      rr:template "frpm {CDSCode}" ;
      rr:termType rr:Literal
    ]
  ]
 ;
  rr:predicateObjectMap [
    rr:predicate <http://california_schools.org/frpm#CDSCode> ;
    rr:objectMap [ rml:reference "CDSCode" ]
  ] ;
  rr:predicateObjectMap [
    rr:predicate <http://california_schools.org/frpm#ref-CDSCode> ;
    rr:objectMap [
      rr:template "http://california_schools.org/schools/CDSCode={CDSCode}" ;
      rr:termType rr:IRI
    ]
  ] ;
  rr:predicateObjectMap [
    rr:predicate <http://california_schools.org/frpm#Academic Year> ;
