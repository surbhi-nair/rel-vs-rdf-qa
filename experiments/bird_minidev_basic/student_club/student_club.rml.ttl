@prefix rr: <http://www.w3.org/ns/r2rml#> .
@prefix rml: <http://semweb.mmlab.be/ns/rml#> .
@prefix ql: <http://semweb.mmlab.be/ns/ql#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix : <http://student_club.org/> .

######################################################################
# Table: event
######################################################################
<#event_Mapping>
  rml:logicalSource [
    rml:source "student_club.sqlite" ;
    rml:referenceFormulation ql:SQL ;
    rml:query '''SELECT "event_id", "event_name", "event_date", "type", "notes", "location", "status" FROM "event"'''
  ] ;
  rr:subjectMap [
    rr:template "http://student_club.org/event/event_id={event_id}" ;
    rr:class <http://student_club.org/event>
  ] ;
  rr:predicateObjectMap [
    rr:predicate rdfs:label ;
    rr:objectMap [
      rr:template "event {event_id}" ;
      rr:termType rr:Literal
    ]
  ]
 ;
  rr:predicateObjectMap [
    rr:predicate <http://student_club.org/event#event_id> ;
    rr:objectMap [ rml:reference "event_id" ]
  ] ;
  rr:predicateObjectMap [
    rr:predicate <http://student_club.org/event#event_name> ;
    rr:objectMap [ rml:reference "event_name" ]
  ] ;
  rr:predicateObjectMap [
    rr:predicate <http://student_club.org/event#event_date> ;
    rr:objectMap [ rml:reference "event_date" ]
  ] ;
  rr:predicateObjectMap [
    rr:predicate <http://student_club.org/event#type> ;
    rr:objectMap [ rml:reference "type" ]
  ] ;
  rr:predicateObjectMap [
    rr:predicate <http://student_club.org/event#notes> ;
    rr:objectMap [ rml:reference "notes" ]
  ] ;
  rr:predicateObjectMap [
    rr:predicate <http://student_club.org/event#location> ;
    rr:objectMap [ rml:reference "location" ]
  ] ;
  rr:predicateObjectMap [
    rr:predicate <http://student_club.org/event#status> ;
    rr:objectMap [ rml:reference "status" ]
  ]
 .

