    rr:objectMap [ rml:reference "link_to_event" ]
  ] ;
  rr:predicateObjectMap [
    rr:predicate <http://student_club.org/attendance#ref-link_to_event> ;
    rr:objectMap [
      rr:template "http://student_club.org/event/event_id={link_to_event}" ;
      rr:termType rr:IRI
    ]
  ] ;
  rr:predicateObjectMap [
    rr:predicate <http://student_club.org/attendance#link_to_member> ;
