@prefix rr: <http://www.w3.org/ns/r2rml#> .
@prefix rml: <http://semweb.mmlab.be/ns/rml#> .
@prefix ql: <http://semweb.mmlab.be/ns/ql#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix : <http://toxicology.org/> .

######################################################################
# Table: atom
######################################################################
<#atom_Mapping>
  rml:logicalSource [
    rml:source "toxicology.sqlite" ;
    rml:referenceFormulation ql:SQL ;
    rml:query '''SELECT "atom_id", "molecule_id", "element" FROM "atom"'''
  ] ;
  rr:subjectMap [
    rr:template "http://toxicology.org/atom/atom_id={atom_id}" ;
    rr:class <http://toxicology.org/atom>
  ] ;
  rr:predicateObjectMap [
    rr:predicate rdfs:label ;
    rr:objectMap [
      rr:template "atom {atom_id}" ;
      rr:termType rr:Literal
    ]
  ]
 ;
  rr:predicateObjectMap [
    rr:predicate <http://toxicology.org/atom#atom_id> ;
    rr:objectMap [ rml:reference "atom_id" ]
  ] ;
  rr:predicateObjectMap [
    rr:predicate <http://toxicology.org/atom#molecule_id> ;
    rr:objectMap [ rml:reference "molecule_id" ]
  ] ;
  rr:predicateObjectMap [
    rr:predicate <http://toxicology.org/atom#ref-molecule_id> ;
    rr:objectMap [
      rr:template "http://toxicology.org/molecule/molecule_id={molecule_id}" ;
      rr:termType rr:IRI
    ]
  ] ;
  rr:predicateObjectMap [
    rr:predicate <http://toxicology.org/atom#element> ;
    rr:objectMap [ rml:reference "element" ]
  ]
 .

