@prefix rr: <http://www.w3.org/ns/r2rml#> .
@prefix rml: <http://semweb.mmlab.be/ns/rml#> .
@prefix ql: <http://semweb.mmlab.be/ns/ql#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix : <http://financial.org/> .

######################################################################
# Table: account
######################################################################
<#account_Mapping>
  rml:logicalSource [
    rml:source "financial.sqlite" ;
    rml:referenceFormulation ql:SQL ;
    rml:query '''SELECT "account_id", "district_id", "frequency", "date" FROM "account"'''
  ] ;
  rr:subjectMap [
    rr:template "http://financial.org/account/account_id={account_id}" ;
    rr:class <http://financial.org/account>
  ] ;
  rr:predicateObjectMap [
    rr:predicate rdfs:label ;
    rr:objectMap [
      rr:template "account {account_id}" ;
      rr:termType rr:Literal
    ]
  ]
 ;
  rr:predicateObjectMap [
    rr:predicate <http://financial.org/account#account_id> ;
    rr:objectMap [ rml:reference "account_id" ]
  ] ;
  rr:predicateObjectMap [
    rr:predicate <http://financial.org/account#district_id> ;
    rr:objectMap [ rml:reference "district_id" ]
  ] ;
  rr:predicateObjectMap [
    rr:predicate <http://financial.org/account#ref-district_id> ;
    rr:objectMap [
      rr:template "http://financial.org/district/district_id={district_id}" ;
      rr:termType rr:IRI
    ]
  ] ;
  rr:predicateObjectMap [
    rr:predicate <http://financial.org/account#frequency> ;
    rr:objectMap [ rml:reference "frequency" ]
  ] ;
  rr:predicateObjectMap [
    rr:predicate <http://financial.org/account#date> ;
    rr:objectMap [ rml:reference "date" ]
  ]
 .

