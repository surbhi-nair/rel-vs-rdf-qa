@prefix rr: <http://www.w3.org/ns/r2rml#> .
@prefix rml: <http://semweb.mmlab.be/ns/rml#> .
@prefix ql: <http://semweb.mmlab.be/ns/ql#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix : <http://superhero.org/> .

######################################################################
# Table: alignment
######################################################################
<#alignment_Mapping>
  rml:logicalSource [
    rml:source "superhero.sqlite" ;
    rml:referenceFormulation ql:SQL ;
    rml:query '''SELECT "id", "alignment" FROM "alignment"'''
  ] ;
  rr:subjectMap [
    rr:template "http://superhero.org/alignment/id={id}" ;
    rr:class <http://superhero.org/alignment>
  ] ;
  rr:predicateObjectMap [
    rr:predicate rdfs:label ;
    rr:objectMap [
      rr:template "alignment {id}" ;
      rr:termType rr:Literal
    ]
  ]
 ;
  rr:predicateObjectMap [
    rr:predicate <http://superhero.org/alignment#id> ;
    rr:objectMap [ rml:reference "id" ]
  ] ;
  rr:predicateObjectMap [
    rr:predicate <http://superhero.org/alignment#alignment> ;
    rr:objectMap [ rml:reference "alignment" ]
  ]
 .

