    ]
  ] ;
  rr:predicateObjectMap [
    rr:predicate <http://superhero.org/superhero#race_id> ;
    rr:objectMap [ rml:reference "race_id" ]
  ] ;
  rr:predicateObjectMap [
    rr:predicate <http://superhero.org/superhero#ref-race_id> ;
