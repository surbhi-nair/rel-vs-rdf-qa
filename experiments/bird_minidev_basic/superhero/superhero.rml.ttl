######################################################################
# Table: superhero
######################################################################
<#superhero_Mapping>
  rml:logicalSource [
    rml:source "superhero.sqlite" ;
    rml:referenceFormulation ql:SQL ;
    rml:query '''SELECT "id", "superhero_name", "full_name", "gender_id", "eye_colour_id", "hair_colour_id", "skin_colour_id", "race_id", "publisher_id", "alignment_id", "height_cm", "weight_kg" FROM "superhero"'''
  ] ;
  rr:subjectMap [
    rr:template "http://superhero.org/superhero/id={id}" ;
    rr:class <http://superhero.org/superhero>
  ] ;
  rr:predicateObjectMap [
    rr:predicate rdfs:label ;
    rr:objectMap [
      rr:template "superhero {id}" ;
      rr:termType rr:Literal
    ]
  ]
 ;
  rr:predicateObjectMap [
    rr:predicate <http://superhero.org/superhero#id> ;
    rr:objectMap [ rml:reference "id" ]
  ] ;
  rr:predicateObjectMap [
    rr:predicate <http://superhero.org/superhero#superhero_name> ;
    rr:objectMap [ rml:reference "superhero_name" ]
  ] ;
  rr:predicateObjectMap [
    rr:predicate <http://superhero.org/superhero#full_name> ;
    rr:objectMap [ rml:reference "full_name" ]
  ] ;
  rr:predicateObjectMap [
    rr:predicate <http://superhero.org/superhero#gender_id> ;
    rr:objectMap [ rml:reference "gender_id" ]
  ] ;
  rr:predicateObjectMap [
    rr:predicate <http://superhero.org/superhero#ref-gender_id> ;
    rr:objectMap [
      rr:template "http://superhero.org/gender/id={gender_id}" ;
      rr:termType rr:IRI
    ]
  ] ;
  rr:predicateObjectMap [
    rr:predicate <http://superhero.org/superhero#eye_colour_id> ;
    rr:objectMap [ rml:reference "eye_colour_id" ]
  ] ;
  rr:predicateObjectMap [
